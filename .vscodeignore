# Editor and local workspace state
.vscode/**
.vscode-test/**
.gitignore
.vscodeignore
.yarnrc

# Source — excluded, EXCEPT the runtime assets the webviews load straight from src/
# at runtime (see my-skills.ts: joinPath(extensionUri, 'src', …, '*.html'/'*.css'/'*.webp')).
# Covers My Skills under src/my-skills/ and the shared tutorials under
# src/shared/tutorial/ (+ their images in src/shared/assets/). Do NOT remove these
# negations or the panels render blank.
src/**
!src/shared/
!src/shared/**/
!src/shared/**/*.html
!src/shared/**/*.css
!src/shared/**/*.svg
!src/shared/**/*.png
!src/shared/**/*.webp
!src/my-skills/
!src/my-skills/**/
!src/my-skills/**/*.html
!src/my-skills/**/*.css
!src/my-skills/**/*.svg
!src/my-skills/**/*.png
!src/my-skills/**/*.webp

# Smart + Skills mode reads its rules asset (assets/skills/default/SKILL.md) from
# src/my-plus/ at runtime via extensionUri (see my-smart/core/smart-service.ts:
# loadRules → RULES_ASSET_SEGMENTS). Without these negations the packaged build
# can't write the workspace .f1/ folder — only graphify-out/ shows up.
!src/my-plus/
!src/my-plus/**/
!src/my-plus/**/*.md

# Repo/GitHub-only assets (~13 MB, screenshot.gif etc) — not loaded by the extension
public/**

# Tests and generated development maps
**/__test__/**
**/__tests__/**
**/*.test.*
**/*.spec.*
**/*.ts
**/*.map

# Build, lint, typecheck, and package-manager inputs
.prettierignore
bun.lock
esbuild.js
**/eslint.config.mjs
**/tsconfig.json

# Native debug symbols — never loaded at runtime (trims ~53 MB of node-pty .pdb files)
**/*.pdb

# fixnow bundles dictionaries for 8 languages (~11 MB). F1's Prompt picker
# spellchecks en/es/pt/ru (zh is character-based — fixnow has no dict for it).
# Keep those four, drop the unused four (loaded from node_modules at runtime;
# fixnow is external). Mirror src/my-cli/shared/prompt/languages.ts.
node_modules/fixnow/dictionaries/ar/**
node_modules/fixnow/dictionaries/de/**
node_modules/fixnow/dictionaries/fr/**
node_modules/fixnow/dictionaries/vi/**

# Project notes and contributor-only documentation
AGENTS.md
ARCHITECTURE.md
CLAUDE.md
CODE_OF_CONDUCT.md
CONTRIBUTING.md
NOTES.md
vsc-extension-quickstart.md

# Agent/context caches and graph analysis output
.agents/**
.claude/**
.codex/**

# Local package artifacts
*.vsix
