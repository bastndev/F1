{
  "name": "f1",
  "displayName": "F1 (CLI Hub)",
  "description": "Available now: VSCode • Cursor • Windsurf • Trae.ai • Kiro & (Firebase Studio)... 雨",
  "version": "1.0.0",
  "publisher": "bastndev",
  "license": "MIT",
  "preview": true,
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "F1 Quick Switch",
    "productivity",
    "keys maps",
    "toggle",
    "f1"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "homepage": "https://github.com/bastndev/F1#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bastndev/F1.git"
  },
  "bugs": {
    "url": "https://github.com/bastndev/F1/issues/new"
  },
  "author": {
    "name": "Gohit (X) Bastian", 
    "email": "bastndev@gohit.xyz",
    "url": "https://www.gohit.xyz/me"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/bastndev"
  },

  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "keybindings": [
      {
        "command": "f1.cliHub.focus",
        "key": "f1",
        "mac": "f1"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "cliHubContainer",
          "title": "CLI Hub",
          "icon": "$(symbol-event)"
        }
      ]
    },
    "views": {
      "cliHubContainer": [
        {
          "type": "webview",
          "id": "f1.cliHub",
          "name": "CLI Hub",
          "icon": "$(symbol-event)"
        }
      ]
    }
  },

  "scripts": {
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/vscode": "^1.43.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.21.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.32.1"
  }
}