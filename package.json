{
  "name": "f1",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "2.1.2",
  "publisher": "bastndev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Other",
    "Visualization"
  ],
  "keywords": [
    "ai",
    "IDE",
    "ai assistant",
    "llm",
    "composer",
    "agent",
    "agents",
    "claude",
    "claude code",
    "codex",
    "copilot",
    "cursor",
    "kiro",
    "grok",
    "antigravity",
    "kilocode",
    "opencode",
    "chatgpt",
    "cli",
    "terminal",
    "prompt",
    "skills",
    "memory",
    "AGENTS.md",
    "CLAUDE.md",
    "DESIGN.md",
    "f1",
    "code",
    "quick switch",
    "keymaps",
    "CLI Hub",
    "My skills",
    "My Memory",
    "productivity"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "homepage": "https://github.com/bastndev/F1#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bastndev/F1.git"
  },
  "bugs": {
    "url": "https://github.com/bastndev/F1/issues/new"
  },
  "author": {
    "name": "Gohit (X) Bastian",
    "email": "bastndev@gohit.xyz",
    "url": "https://www.gohit.xyz/me"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/bastndev"
  },

  "l10n": "./l10n",
  "activationEvents": [],
  "main": "./dist/extension.js",

  "contributes": {
    "commands": [
      {
        "command": "f1.myCli.openTutorial",
        "title": "Open CLI Hub Tutorial",
        "category": "F1"
      },
      {
        "command": "f1.myCli.smartFocus",
        "title": "Focus CLI Hub",
        "category": "F1"
      },
      {
        "command": "f1.lynxKeymap.prompt",
        "title": "Install Lynx Keymap",
        "category": "F1"
      }
    ],
    "keybindings": [
      {
        "command": "f1.myCli.smartFocus",
        "key": "f1",
        "mac": "f1"
      },
      {
        "command": "myskills-panel.focus",
        "key": "ctrl+3",
        "mac": "ctrl+3"
      },
      {
        "key": "ctrl+[Backquote]",
        "mac": "cmd+[Backquote]",
        "command": "workbench.action.toggleMaximizedPanel"
      },
      {
        "key": "alt+f1",
        "mac": "alt+f1",
        "command": "-editor.action.accessibilityHelp"
      },
      {
        "command": "f1.lynxKeymap.prompt",
        "key": "alt+capslock",
        "mac": "alt+capslock"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "myskills-activity",
          "title": "My Skills",
          "icon": "$(symbol-event)"
        }
      ],
      "panel": [
        {
          "id": "myCliContainer",
          "title": "CLI Hub",
          "icon": "$(symbol-event)"
        }
      ]
    },
    "views": {
      "myskills-activity": [
        {
          "type": "webview",
          "id": "myskills-panel",
          "name": "My Skills",
          "icon": "$(symbol-event)"
        }
      ],
      "myCliContainer": [
        {
          "type": "webview",
          "id": "f1.myCli",
          "name": "CLI Hub",
          "icon": "$(symbol-event)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "@types/vscode": "^1.43.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.21.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.32.1"
  },
  "dependencies": {
    "fixnow": "^2.0.4",
    "node-pty": "1.1.0"
  }
}
