{
  "name": "f1",
  "displayName": "F1",
  "description": "Available now: VSCode • Cursor • Windsurf • Trae.ai • Kiro & (Firebase Studio)... 雨",
  "version": "1.0.0",
  "publisher": "bastndev",
  "license": "MIT",
  "preview": true,
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "AI",
    "Snippets",
    "Visualization"
  ],
  "keywords": [
    "F1 Quick Switch",
    "productivity",
    "keys maps",
    "toggle",
    "f1",
    "My Skills",
    "Skills",
    "agent",
    "AGENTS.md",
    "CLAUDE.md",
    "DESIGN.md",
    "agents",
    "claude",
    "marketplace"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "homepage": "https://github.com/bastndev/F1#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bastndev/F1.git"
  },
  "bugs": {
    "url": "https://github.com/bastndev/F1/issues/new"
  },
  "author": {
    "name": "Gohit (X) Bastian",
    "email": "bastndev@gohit.xyz",
    "url": "https://www.gohit.xyz/me"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/bastndev"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "keybindings": [
      {
        "command": "f1.myCli.focus",
        "key": "f1",
        "mac": "f1"
      },
      {
        "command": "myskills-panel.focus",
        "key": "ctrl+3",
        "mac": "ctrl+3"
      },
      {
        "key": "ctrl+[Backquote]",
        "mac": "cmd+[Backquote]",
        "command": "workbench.action.toggleMaximizedPanel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "myskills-activity",
          "title": "My Skills",
          "icon": "$(symbol-event)"
        }
      ],
      "panel": [
        {
          "id": "myCliContainer",
          "title": "CLI Hub",
          "icon": "$(symbol-event)"
        }
      ]
    },
    "views": {
      "myskills-activity": [
        {
          "type": "webview",
          "id": "myskills-panel",
          "name": "My Skills",
          "icon": "$(symbol-event)"
        }
      ],
      "myCliContainer": [
        {
          "type": "webview",
          "id": "f1.myCli",
          "name": "CLI Hub",
          "icon": "$(symbol-event)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/vscode": "^1.43.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.21.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.32.1"
  },
  "dependencies": {
    "@cspell/dict-es-es": "^3.0.8",
    "cspell-trie-lib": "^8.9.1",
    "node-pty": "1.1.0"
  }
}
